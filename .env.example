# PixelWorld 环境变量配置
# 复制此文件为 .env 并填入真实值
# .env 文件不会被提交到 Git 仓库

# ============================================
# AI Provider 选择
# ============================================
# 可选: mimo | nvidia | mock
AI_PROVIDER=mock

# ============================================
# MiMo Provider 配置
# ============================================
MIMO_API_KEY=your_mimo_key_here
MIMO_BASE_URL=https://your-mimo-openai-compatible-endpoint
MIMO_WORLD_MODEL=mimo-world-model-name
MIMO_MAJOR_NPC_MODEL=mimo-npc-model-name

# ============================================
# NVIDIA NIM Provider 配置
# ============================================
NVIDIA_API_KEY=your_nvidia_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_WORLD_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_MAJOR_NPC_MODEL=meta/llama-3.1-8b-instruct

# ============================================
# 本地 NPC Provider 配置
# ============================================
# 可选: rule_based | ollama | llama_cpp | gguf
LOCAL_NPC_PROVIDER=rule_based
LOCAL_NPC_MODEL_PATH=res://models/tiny_npc_model.gguf

# ============================================
# AI Gateway 配置 (正式推荐模式)
# ============================================
# 如果使用 AI Gateway 中转，取消以下注释并配置：
# AI_GATEWAY_URL=http://localhost:8080
# AI_GATEWAY_AUTH_TOKEN=your_gateway_token

# ============================================
# 游戏配置
# ============================================
GAME_LOG_LEVEL=info
GAME_DEBUG_MODE=false
